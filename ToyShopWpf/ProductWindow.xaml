<Window x:Class="ToyShopWpf.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ToyShopWpf"
        mc:Ignorable="d" Style="{StaticResource Windows}"
        Title="Продукты" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding UserFullName}"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Right"
                   Margin="20 10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Products}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10"
                                Background="{Binding Background}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="80" Height="80" Margin="15 0">
                                    <Image Source="{Binding Photo}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Provider.Name}"/>
                                    <TextBlock Text="{Binding Creator.Name}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Цена: "/>
                                        <TextBlock Text="{Binding Price}"/>
                                    </StackPanel>
                                    <TextBlock>
                                        <Run Text="{Binding AmountInStock}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Unit.Name}"/>
                                    </TextBlock> 
                                </StackPanel>
                                <Border Grid.Column="2">
                                    <TextBlock Text="{Binding Discount}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Command="{Binding LogOutCommand}"
                Content="Выйти"
                Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                />

    </Grid>
</Window>
